# ═══════════════════════════════════════════════════════════════════════════
# FICHIER MODÈLE — ce fichier est versionné (.env.example). Il ne contient pas de secrets.
#
# Une seule fois, pour créer ton fichier local de secrets :
#   npm run env:bootstrap
# Cela copie ce fichier vers .env.local (seulement si .env.local n’existe pas encore).
#
# Ensuite : ouvre .env.local dans Cursor, et pour chaque ligne "NOM="
# remplace la partie vide par ta valeur (sans espaces autour du "=").
# Exemple : GEMINI_API_KEY=AIzaSy...   (pas de guillemets sauf si la valeur en a besoin)
#
# .env.local est ignoré par git (.gitignore) : tes clés ne partent pas sur GitHub.
# ═══════════════════════════════════════════════════════════════════════════

# URL publique de l’app (callbacks Stripe, emails, liens)
# Local : http://localhost:3000 — Production v1 : https://fitmangas.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alias historique (optionnel)
APP_URL=http://localhost:3000

# Référence projet (Dashboard → Settings → General → Reference ID), pour : npm run db:link
SUPABASE_PROJECT_REF=
# CLI Supabase (optionnel : utile pour CI/CD ou si la CLI demande le mot de passe DB)
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# E-mails autorisés à accéder à /admin (séparés par virgules)
ADMIN_EMAILS=
# Serveur uniquement (webhook Stripe, CRUD cours /admin/courses via service role, etc.) — ne jamais exposer au client
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (Dashboard Stripe → Produits → Prix) — un par offre fitmangas
STRIPE_PRICE_ID_VISIO_COLLECTIF=
STRIPE_PRICE_ID_VISIO_INDIVIDUEL=
STRIPE_PRICE_ID_NANTES_COLLECTIF=
STRIPE_PRICE_ID_NANTES_INDIVIDUEL=
# Coupon Stripe 100 % parrainage (mode LIVE) — appliqué à la marraine à 5 filleules actives
STRIPE_REFERRAL_REWARD_COUPON_ID=

# Blog — génération IA (cascade Gemini → Mistral → Groq → OpenAI)
GEMINI_API_KEY=
# Optionnel : défaut côté code = gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash

# Community Manager — Meta (Instagram + Facebook Page)
# App Meta Business : https://developers.facebook.com/
# Redirect OAuth : {NEXT_PUBLIC_APP_URL}/api/admin/community/meta/callback
META_APP_ID=
META_APP_SECRET=
MISTRAL_API_KEY=
# Défaut : mistral-small-latest (bon FR, free tier)
MISTRAL_MODEL=mistral-small-latest
GROQ_API_KEY=
# Défaut : llama-3.3-70b-versatile (peut être indispo selon région)
GROQ_MODEL=llama-3.3-70b-versatile
UNSPLASH_ACCESS_KEY=
# Si true (défaut), bloque la validation admin si EN/ES manquent
BLOG_REQUIRE_TRANSLATIONS=true
# Optionnel : 4e repli de la cascade
OPENAI_API_KEY=
OPENAI_MODEL=

# Newsletter (double opt-in + envoi publication). Si absent : mode dev sans envoi email réel.
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=

# Seed test data (optionnel)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Google Cloud — Analytics & Search Console (service account)
GOOGLE_SERVICE_ACCOUNT_JSON=
GA4_PROPERTY_ID=537748245

# Vimeo (replays) — fichiers à uploader depuis le disque (route /api/video/process-recording)
VIMEO_CLIENT_ID=
VIMEO_CLIENT_SECRET=
VIMEO_ACCESS_TOKEN=
# Webhook Vimeo → POST /api/webhooks/vimeo (signature HMAC avec ce secret)
VIMEO_WEBHOOK_SECRET=
# UUID profil Supabase (auth.users / profiles.id) — associé aux vidéos créées par le webhook
VIMEO_DEFAULT_COACH_ID=

# Cron publication programmée — GET /api/admin/vimeo/cron/publish-scheduled (Bearer ou ?secret=)
CRON_SECRET=
# Optionnel : secret HMAC du flux calendrier abonné (/api/calendar/feed/…).
# Si absent, le serveur utilise SUPABASE_SERVICE_ROLE_KEY (déjà présent).
CALENDAR_FEED_SECRET=
# Ingestion replays Jibri (machine-to-machine) — POST /api/internal/recordings/ingest
RECORDING_INGEST_SECRET=
# En local : dossier du projet ex. recordings-local ; sur serveur : chemin absolu vers les exports Jitsi
VIDEO_RECORDINGS_DIR=

# Printful boutique
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=
# Secret HMAC configuré dans Printful pour signer les webhooks boutique
PRINTFUL_WEBHOOK_SECRET=

# Jitsi live — identifiants JWT pour créer des salons modérateur/cliente sécurisés
JITSI_APP_ID=
# Secret privé Jitsi/JaaS utilisé uniquement côté serveur pour signer les JWT
JITSI_APP_SECRET=
# Audience JWT attendue par Jitsi (souvent "jitsi" ou valeur JaaS)
JITSI_JWT_AUD=
# Émetteur JWT attendu par Jitsi/JaaS
JITSI_JWT_ISS=
# Sujet JWT attendu par Jitsi/JaaS
JITSI_JWT_SUB=
# Identifiant de clé JWT si votre configuration Jitsi/JaaS en exige un
JITSI_JWT_KID=
# Domaine public Jitsi utilisé par l’iframe côté navigateur
NEXT_PUBLIC_JITSI_DOMAIN=

# Landing (configuration publique)
NEXT_PUBLIC_LANDING_HERO_IMAGE_URL=
NEXT_PUBLIC_LANDING_INSTAGRAM_URL=
NEXT_PUBLIC_LANDING_CONTACT_EMAIL=
NEXT_PUBLIC_LANDING_WHATSAPP_PHONE=
# Numéro WhatsApp au format international E.164, ex. +33600000000
NEXT_PUBLIC_WHATSAPP_E164=
# Affiche/masque les éléments publics liés à l’offre Mexique
NEXT_PUBLIC_SHOW_MEXICO=

# Google Search Console — URL exacte de la propriété suivie
GSC_SITE_URL=

# Notifications web push — clé publique visible côté navigateur
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Notifications web push — clé privée serveur pour signer les envois push
VAPID_PRIVATE_KEY=
# Limite quotidienne d’e-mails de notification par utilisateur
NOTIFICATION_EMAIL_DAILY_CAP=
# Limite quotidienne de notifications in-app non lues par utilisateur
NOTIFICATION_INAPP_UNREAD_DAILY_CAP=
# Début des heures calmes notifications, format HH:mm
NOTIFICATION_QUIET_HOURS_START=
# Fin des heures calmes notifications, format HH:mm
NOTIFICATION_QUIET_HOURS_END=
# Objectif mensuel de séances affiché côté client
NEXT_PUBLIC_MONTHLY_SESSION_GOAL=
# Nombre de jours sans activité avant de déclencher une relance
INACTIVITY_DAYS_THRESHOLD=
